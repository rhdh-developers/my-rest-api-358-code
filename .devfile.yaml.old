schemaVersion: 2.2.2
metadata:
  name: my-rest-api-358
  displayName: my-rest-api-358 – Python FastAPI
  description: OpenShift Dev Spaces environment for my-rest-api-358
  language: Python
  projectType: FastAPI

attributes:
  controller.devfile.io/storage-type: ephemeral

projects:
  - name: my-rest-api-358-code
    git:
      remotes:
        origin: https://github.com/rhdh-developers/my-rest-api-358-code.git
      checkoutFrom:
        revision: main

components:
  - name: python
    container:
      image: quay.io/devfile/universal-developer-image:ubi9-latest
      memoryLimit: '2Gi'
      memoryRequest: '1Gi'
      cpuLimit: '2'
      cpuRequest: '1'
      mountSources: true
      volumeMounts:
        - name: venv
          path: /home/user/.venv
  - name: venv
    volume:
      size: 1G

commands:
  - id: install-deps
    exec:
      component: python
      commandLine: python -m venv /home/user/.venv && . /home/user/.venv/bin/activate && pip install -r requirements.txt
      workingDir: ${PROJECT_SOURCE}
      label: Install Dependencies
      group:
        kind: build
        isDefault: true

  - id: run-dev
    exec:
      component: python
      commandLine: . /home/user/.venv/bin/activate && uvicorn main:app --reload --host 0.0.0.0 --port 8000
      workingDir: ${PROJECT_SOURCE}
      label: Run Dev Server
      group:
        kind: run
        isDefault: true

  - id: run-tests
    exec:
      component: python
      commandLine: . /home/user/.venv/bin/activate && python -m pytest -v
      workingDir: ${PROJECT_SOURCE}
      label: Run Tests
      group:
        kind: test
        isDefault: true
